  {
    "id": "ac_map_tpl",
    "type": "ui-template",
    "z": "ac_tab",
    "group": "ac_grp_map",
    "name": "Leaflet Ground Track",
    "order": 1,
    "width": "12",
    "height": "12",
    "format": "<template>\n  <div style=\"width:100%;height:500px;background:#111\">\n    <div ref=\"mapEl\" style=\"width:100%;height:100%\"/>\n  </div>\n</template>\n<script>\nexport default {\n  props: ['msg'],\n  data() { return { ready:false, markers:{}, trails:{} } },\n  mounted() { this.$nextTick(() => this.init()); },\n  beforeUnmount() { if (this._map) { this._map.remove(); this._map = null; } },\n  watch: {\n    msg(v) { if (v?.payload) this.update(v.payload); }\n  },\n  methods: {\n    col(inc) { return inc<50?'#ff7700':inc<60?'#00aaff':inc<75?'#00ee88':'#cc44ff'; },\n    init() {\n      const loadCSS = href => {\n        if (!document.querySelector(`link[href=\"${href}\"]`)) {\n          const l=document.createElement('link'); l.rel='stylesheet'; l.href=href;\n          document.head.appendChild(l);\n        }\n      };\n      const loadJS = src => new Promise(res => {\n        if (document.querySelector(`script[src=\"${src}\"]`)) { res(); return; }\n        const s=document.createElement('script'); s.src=src; s.onload=res;\n        document.head.appendChild(s);\n      });\n      loadCSS('https://unpkg.com/leaflet@1.9.4/dist/leaflet.css');\n      loadJS('https://unpkg.com/leaflet@1.9.4/dist/leaflet.js').then(() => {\n        const L = window.L;\n        this._map = L.map(this.$refs.mapEl, { center:[30,0], zoom:2, preferCanvas:true });\n        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {\n          attribution:'&copy; OSM contributors &copy; CARTO', subdomains:'abcd', maxZoom:19\n        }).addTo(this._map);\n        this._layer = L.layerGroup().addTo(this._map);\n        this.ready = true;\n        if (this._pending) { this.update(this._pending); this._pending = null; }\n      });\n    },\n    update(sats) {\n      if (!this.ready) { this._pending = sats; return; }\n      const L = window.L;\n      const active = new Set(sats.map(s => s.name));\n      // Remove satellites that dropped below horizon\n      Object.keys(this.markers).forEach(n => {\n        if (!active.has(n)) {\n          this.markers[n].remove(); delete this.markers[n];\n          if (this.trails[n]) { this.trails[n].remove(); delete this.trails[n]; }\n        }\n      });\n      sats.forEach(sat => {\n        const c = this.col(sat.inc);\n        if (this.markers[sat.name]) {\n          this.markers[sat.name].setLatLng([sat.lat, sat.lon])\n            .setStyle({color:c, fillColor:c});\n        } else {\n          this.markers[sat.name] = L.circleMarker([sat.lat, sat.lon], {\n            radius:3, color:c, fillColor:c, fillOpacity:0.9, weight:0\n          }).bindTooltip(sat.name, {opacity:0.85}).addTo(this._layer);\n        }\n        if (sat.trail && sat.trail.length > 1) {\n          const pts = [...sat.trail, {lat:sat.lat, lon:sat.lon}].map(p => [p.lat, p.lon]);\n          if (this.trails[sat.name]) {\n            this.trails[sat.name].setLatLngs(pts);\n          } else {\n            this.trails[sat.name] = L.polyline(pts, {\n              color:c, weight:0.8, opacity:0.35\n            }).addTo(this._layer);\n          }\n        }\n      });\n    }\n  }\n}\n</script>",
    "storeOutMessages": false,
    "fwdInMessages": false,
    "resendOnRefresh": true,
